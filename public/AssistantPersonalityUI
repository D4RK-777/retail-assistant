// --- Main App Component ---
function App() {
    const [currentPersona, setCurrentPersona] = useState(PERSONA_DATA["The Mentor"]);
    const [messages, setMessages] = useState([]);
    const [input, setInput] = useState('');
    const [isLoading, setIsLoading] = useState(false);
    const chatEndRef = useRef(null);

    // Effect to set the initial welcome message when the persona changes
    useEffect(() => {
        setMessages([{
            text: `Hello! I'm ${currentPersona.name}. ${currentPersona.tagline} How can I assist you today?`,
            sender: 'bot'
        }]);
    }, [currentPersona]);

    // Effect to scroll to the latest message
    useEffect(() => {
        chatEndRef.current?.scrollIntoView({ behavior: 'smooth' });
    }, [messages]);

    // --- API Call Logic ---
    const getBotResponse = async (userInput, persona) => {
        setIsLoading(true);
        const fullPrompt = `${persona.prompt}\n\nUser's message: "${userInput}"`;
        
        // Construct the payload for the Gemini API
        const payload = {
            contents: [{
                role: "user",
                parts: [{ text: fullPrompt }]
            }]
        };
        
        const apiKey = ""; // API key will be automatically managed by the environment
        const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-05-20:generateContent?key=${apiKey}`;

        try {
            // Using exponential backoff for retries
            let response;
            let retries = 3;
            let delay = 1000;
            for (let i = 0; i < retries; i++) {
                response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (response.ok) break;
                await new Promise(res => setTimeout(res, delay));
                delay *= 2;
            }

            if (!response.ok) {
                throw new Error(`API request failed with status ${response.status}`);
            }

            const result = await response.json();
            
            const botText = result?.candidates?.[0]?.content?.parts?.[0]?.text;
            if (botText) {
                setMessages(prev => [...prev, { text: botText, sender: 'bot' }]);
            } else {
                 setMessages(prev => [...prev, { text: "I'm sorry, I encountered an issue. Could you please rephrase?", sender: 'bot' }]);
            }
        } catch (error) {
            console.error("Error fetching bot response:", error);
            setMessages(prev => [...prev, { text: "My apologies, I'm having trouble connecting right now. Please try again in a moment.", sender: 'bot' }]);
        } finally {
            setIsLoading(false);
        }
    };

    const handleSend = () => {
        if (input.trim() && !isLoading) {
            const userMessage = { text: input, sender: 'user' };
            setMessages(prev => [...prev, userMessage]);
            getBotResponse(input, currentPersona);
            setInput('');
        }
    };

    const handleKeyPress = (e) => {
        if (e.key === 'Enter') {
            handleSend();
        }
    };

    return (
        <div className="font-sans bg-gray-900 text-white flex h-screen antialiased">
            {/* --- Persona Selector Sidebar --- */}
            <div className="w-1/3 max-w-xs bg-gray-800 p-4 flex flex-col border-r border-gray-700">
                <h1 className="text-2xl font-bold text-center mb-1">AI Assistants</h1>
                <p className="text-sm text-gray-400 text-center mb-6">Select a personality</p>
                <div className="flex-grow overflow-y-auto pr-2">
                    {Object.values(PERSONA_DATA).map(persona => (
                        <button
                            key={persona.name}
                            onClick={() => setCurrentPersona(persona)}
                            className={`w-full text-left p-3 mb-2 rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 ${currentPersona.name === persona.name ? `${persona.bgColor} shadow-lg` : 'bg-gray-700 hover:bg-gray-600'}`}
                        >
                            <p className="font-bold">{persona.name}</p>
                            <p className="text-xs opacity-80">{persona.tagline}</p>
                        </button>
                    ))}
                </div>
            </div>

            {/* --- Main Chat Area --- */}
            <div className="flex-1 flex flex-col">
                {/* Chat Header */}
                <div className={`p-4 ${currentPersona.bgColor} text-white flex items-center shadow-md`}>
                    <div className="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center text-2xl mr-4">
                        {PERSONA_DATA[currentPersona.name] ? PERSONA_DATA[currentPersona.name].name.charAt(4) : 'A'}
                    </div>
                    <div>
                        <h2 className="text-xl font-bold">{currentPersona.name}</h2>
                        <p className="text-sm opacity-90">{currentPersona.tagline}</p>
                    </div>
                </div>

                {/* Chat Window */}
                <div className="flex-1 p-6 overflow-y-auto bg-gray-900">
                    <div className="space-y-6">
                        {messages.map((msg, index) => (
                            <div key={index} className={`flex items-start gap-4 ${msg.sender === 'user' ? 'justify-end' : ''}`}>
                                {msg.sender === 'bot' && <BotIcon persona={currentPersona} />}
                                <div className={`max-w-lg p-4 rounded-xl shadow ${msg.sender === 'user' ? 'bg-blue-600 rounded-bl-xl' : 'bg-gray-700 rounded-br-xl'}`}>
                                    <p className="text-sm whitespace-pre-wrap">{msg.text}</p>
                                </div>
                                {msg.sender === 'user' && <UserIcon />}
                            </div>
                        ))}
                        {isLoading && (
                            <div className="flex items-start gap-4">
                                <BotIcon persona={currentPersona} />
                                <div className="max-w-lg p-4 rounded-xl shadow bg-gray-700">
                                    <div className="flex items-center space-x-2">
                                        <div className="w-2 h-2 bg-gray-400 rounded-full animate-pulse"></div>
                                        <div className="w-2 h-2 bg-gray-400 rounded-full animate-pulse [animation-delay:0.2s]"></div>
                                        <div className="w-2 h-2 bg-gray-400 rounded-full animate-pulse [animation-delay:0.4s]"></div>
                                    </div>
                                </div>
                            </div>
                        )}
                        <div ref={chatEndRef} />
                    </div>
                </div>

                {/* Message Input */}
                <div className="p-4 bg-gray-800 border-t border-gray-700">
                    <div className="flex items-center bg-gray-700 rounded-lg p-2">
                        <input
                            type="text"
                            value={input}
                            onChange={(e) => setInput(e.target.value)}
                            onKeyPress={handleKeyPress}
                            placeholder={`Message ${currentPersona.name}...`}
                            className="flex-1 bg-transparent border-none focus:ring-0 text-white placeholder-gray-400"
                            disabled={isLoading}
                        />
                        <button
                            onClick={handleSend}
                            disabled={isLoading || !input.trim()}
                            className="p-2 rounded-md transition-colors duration-200 text-gray-300 enabled:hover:text-white disabled:opacity-50"
                        >
                            <SendIcon />
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

export default App;
