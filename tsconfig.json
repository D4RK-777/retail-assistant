{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noImplicitAny": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "strictNullChecks": false
  }
,
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "supabase",
    "**/supabase",
    "supabase/**",
    "**/supabase/**",
    "supabase/functions",
    "**/functions",
    "supabase/functions/**",
    "**/supabase/functions/**",
    "**/deno.json",
    "**/import_map.json"
  ]
}
